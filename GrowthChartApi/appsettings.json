{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "UseAzureKeyVault": false,
  "AzureKeyVault": {
    "Url": "https://your-vault-name.vault.azure.net/",
    "SecretName": "PostgresConnectionString"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:9000",
      "http://localhost:3000"
    ]
  },
  "ConnectionStrings": {
    "Postgres": ""
  }
}